{
  "$schema": "https://github.com/ember-theme/ember/blob/main/palette.schema.json",
  "name": "Ember",
  "description": "A warm, monochrome color theme. One vivid coral spark in a sea of warm graphite.",
  "variants": {
    "ember": {
      "name": "Ember",
      "type": "dark",
      "background": { "hex": "#1c1b19", "hsl": [40, 6, 10] },
      "foreground": { "hex": "#d8d0c0", "hsl": [40, 24, 80] }
    },
    "ember-soft": {
      "name": "Ember Soft",
      "type": "dark",
      "background": { "hex": "#242320", "hsl": [45, 6, 13] },
      "foreground": { "hex": "#d8d0c0", "hsl": [40, 24, 80] }
    },
    "ember-light": {
      "name": "Ember Light",
      "type": "light",
      "background": { "hex": "#e6dac4", "hsl": [39, 40, 84] },
      "foreground": { "hex": "#282418", "hsl": [45, 25, 13] }
    }
  },
  "accents": {
    "coral":  { "hex": "#e08060", "role": "Hero accent — keywords, cursor, links", "hsl": [15, 67, 63] },
    "orange": { "hex": "#c09058", "role": "Constants, properties", "hsl": [32, 45, 55] },
    "gold":   { "hex": "#c8b468", "role": "Functions, types", "hsl": [48, 47, 60] },
    "olive":  { "hex": "#8a9868", "role": "Strings", "hsl": [78, 19, 50] },
    "sage":   { "hex": "#80a090", "role": "Methods", "hsl": [150, 14, 56] },
    "steel":  { "hex": "#7890a0", "role": "Muted blue", "hsl": [204, 17, 55] },
    "rose":   { "hex": "#b07878", "role": "Dusty rose", "hsl": [0, 26, 58] },
    "mauve":  { "hex": "#988090", "role": "Faint violet", "hsl": [320, 10, 55] }
  },
  "accents_light": {
    "coral":  { "hex": "#b84c30", "role": "Hero accent — keywords, cursor, links", "hsl": [12, 59, 45] },
    "orange": { "hex": "#946030", "role": "Constants, properties", "hsl": [29, 51, 38] },
    "gold":   { "hex": "#7a6820", "role": "Functions, types", "hsl": [48, 58, 30] },
    "olive":  { "hex": "#4a6830", "role": "Strings", "hsl": [92, 37, 30] },
    "sage":   { "hex": "#386858", "role": "Methods", "hsl": [160, 30, 31] },
    "steel":  { "hex": "#3a6080", "role": "Muted blue", "hsl": [207, 38, 36] },
    "rose":   { "hex": "#905050", "role": "Dusty rose", "hsl": [0, 29, 44] },
    "mauve":  { "hex": "#706070", "role": "Faint violet", "hsl": [300, 8, 41] }
  }
}
